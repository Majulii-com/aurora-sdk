{
	"name": "@majulii/aurora-sdk",
	"version": "0.1.0",
	"description": "Official TypeScript client for Aurora SDK backend — Gen DSL generation (org API key + LLM via hosted Worker).",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./node": {
			"types": "./dist/node.d.ts",
			"import": "./dist/node.js"
		}
	},
	"files": ["dist"],
	"sideEffects": false,
	"dependencies": {
		"axios": "^1.7.9",
		"axios-retry": "^4.5.0"
	},
	"engines": {
		"node": ">=18"
	},
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"prepublishOnly": "npm run build"
	},
	"devDependencies": {
		"@types/node": "^22.13.10",
		"typescript": "^5.9.3"
	},
	"keywords": ["aurora", "dsl", "gen-ui", "cloudflare-workers", "majulii"],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/majulii/aurora-sdk.git"
	},
	"bugs": {
		"url": "https://github.com/majulii/aurora-sdk/issues"
	},
	"homepage": "https://github.com/majulii/aurora-sdk#readme"
}
